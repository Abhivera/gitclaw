# =============================================================================
# GitClaw — copy to .env and fill in values
# =============================================================================

# --- Core (required) ---------------------------------------------------------

# Random string for session encryption (e.g. openssl rand -base64 32)
BETTER_AUTH_SECRET=

# Public URL of this app (no trailing slash)
BETTER_AUTH_URL=http://localhost:3000

# Postgres — matches docker-compose.yml (port 5438, db gitclaw)
DATABASE_URL=postgresql://postgres:postgres@localhost:5438/gitclaw

# --- GitHub OAuth — user sign-in (required) ----------------------------------

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- GitHub App — PR reviews (required for GitHub provider) --------------------

GITHUB_APP_ID=
# PEM key; use \n for line breaks in .env
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
# App slug from your GitHub App settings (required for install URL)
GITHUB_APP_SLUG=

# --- GitLab (required only if using GitLab) ----------------------------------

GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
# Self-hosted GitLab only (optional; default: https://gitlab.com)
GITLAB_BASE_URL=

# --- Bitbucket (required only if using Bitbucket) ----------------------------

BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=

# --- AI (required — pick one provider) ---------------------------------------

# openrouter | groq | openai-compatible | ollama (optional; auto-detects if unset)
AI_PROVIDER=

# OpenRouter (default when AI_PROVIDER is unset and this key is set)
OPENROUTER_API_KEY=

# Groq — set AI_PROVIDER=groq (or only set GROQ_API_KEY to auto-detect)
GROQ_API_KEY=

# OpenAI-compatible — Ollama, OpenAI, Azure, LM Studio, vLLM, ...
# Ollama example: OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_BASE_URL=
OPENAI_API_KEY=

# Model id (optional; defaults: openrouter/free, llama-3.3-70b-versatile, gpt-4o-mini)
GITCLAW_REVIEW_MODEL=

# --- Development (optional) --------------------------------------------------

# Comma-separated tunnel hostnames for ngrok/local webhook testing
# Example: abc123.ngrok-free.app,another-tunnel.ngrok-free.app
ALLOWED_DEV_ORIGINS=
