{
  "name": "gitclaw",
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Abhivera/gitclaw.git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "clean": "node -e \"const fs=require('fs');['.next'].forEach(p=>fs.rmSync(p,{recursive:true,force:true}));try{fs.rmSync('tsconfig.tsbuildinfo')}catch{}\"",
    "desktop:build:next": "cross-env DESKTOP_BUILD=1 APP_URL=http://127.0.0.1:13100 DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:15432/gitclaw npm run build && node desktop/scripts/prepare-standalone.mjs",
    "desktop:install": "npm install --prefix desktop",
    "desktop:dev": "npm run desktop:build:next && npm run desktop:install && npm run start --prefix desktop",
    "desktop:dist": "npm run desktop:build:next && npm run desktop:install && npm run dist --prefix desktop",
    "desktop:dist:dir": "npm run desktop:build:next && npm run desktop:install && npm run dist:dir --prefix desktop"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.86",
    "@ai-sdk/openai-compatible": "^2.0.51",
    "@base-ui/react": "^1.5.0",
    "@openrouter/ai-sdk-provider": "^2.9.1",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "ai": "^6.0.205",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "minimatch": "^10.2.5",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "octokit": "^5.0.5",
    "pg": "^8.21.0",
    "pg-boss": "^12.19.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^22",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^7.8.0",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
